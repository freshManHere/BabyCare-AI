# Environment — copy to .env and fill in values
PORT=3000

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/babycare

# JWT — use a long random string
JWT_SECRET=change_me_to_a_long_random_secret_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000
